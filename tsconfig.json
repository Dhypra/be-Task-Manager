{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": false,
    "sourceMap": false,
    "removeComments": true,
    "allowImportingTsExtensions": false,
    "noEmit": false
  },
  "include": [
    "**/*.ts"
, "app.js"  ],
  "exclude": [
    "node_modules",
    "dist",
    "generated"
  ]
}